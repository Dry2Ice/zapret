{
  "version": 2,
  "failureThreshold": 3,
  "stableMinutes": 15,
  "guardrails": {
    "maxRetries": 10,
    "maxByteOverhead": 3500,
    "qoeFloor": 0.85
  },
  "classes": {
    "cdn_https": {
      "filters": [
        "--filter-tcp=80,443",
        "--hostlist=\"__LISTS__list-general.txt\"",
        "--hostlist=\"__LISTS__list-general-user.txt\"",
        "--hostlist-exclude=\"__LISTS__list-exclude.txt\"",
        "--hostlist-exclude=\"__LISTS__list-exclude-user.txt\"",
        "--ipset-exclude=\"__LISTS__ipset-exclude.txt\"",
        "--ipset-exclude=\"__LISTS__ipset-exclude-user.txt\""
      ],
      "strategy": "multisplit",
      "splitPosPool": [
        1,
        "midsld"
      ],
      "splitSeqovlPool": [
        568,
        664
      ],
      "splitPattern": "__BIN__tls_clienthello_4pda_to.bin"
    },
    "google_quic": {
      "filters": [
        "--filter-udp=443",
        "--hostlist=\"__LISTS__list-google.txt\""
      ],
      "strategy": "fake(2)",
      "fakeQuicPool": [
        "__BIN__quic_initial_www_google_com.bin",
        "__BIN__quic_initial_dbankcloud_ru.bin"
      ],
      "probabilisticFakeRate": 65,
      "ttlAdaptive": true,
      "ttlViable": true,
      "ttlMin": 2,
      "ttlMax": 4
    },
    "discord_udp": {
      "filters": [
        "--filter-udp=19294-19344,50000-50100",
        "--filter-l7=discord,stun"
      ],
      "strategy": "fake(2)",
      "fakeDiscord": "__BIN__quic_initial_dbankcloud_ru.bin",
      "fakeStun": "__BIN__quic_initial_dbankcloud_ru.bin",
      "repeatsPool": [
        2,
        4,
        6
      ],
      "probabilisticFakeRate": 75
    },
    "discord_media_https": {
      "filters": [
        "--filter-tcp=2053,2083,2087,2096,8443",
        "--hostlist-domains=discord.media"
      ],
      "strategy": "multisplit",
      "splitPosPool": [
        1,
        "2,sniext+1",
        "midsld"
      ],
      "splitSeqovlPool": [
        652,
        664,
        681
      ],
      "fragmentJitterPool": [
        "1",
        "2",
        "sniext+1"
      ],
      "splitPattern": "__BIN__tls_clienthello_www_google_com.bin"
    },
    "game_udp_highport": {
      "filters": [
        "--filter-udp=%GameFilterUDP%",
        "--ipset=\"__LISTS__ipset-all.txt\"",
        "--ipset-exclude=\"__LISTS__ipset-exclude.txt\"",
        "--ipset-exclude=\"__LISTS__ipset-exclude-user.txt\""
      ],
      "strategy": "fake(6)",
      "repeatsPool": [
        4,
        6,
        8
      ],
      "anyProtocol": 1,
      "cutoff": "n2",
      "fakeUnknownUdpPool": [
        "__BIN__quic_initial_dbankcloud_ru.bin",
        "__BIN__quic_initial_www_google_com.bin"
      ],
      "probabilisticFakeRate": 50
    }
  }
}
